# Telegram bot token from BotFather
BOT_TOKEN=

# PostgreSQL connection settings

# Local storage configuration

STORAGE_MODE=local
STORAGE_ROOT=/opt/protocols-bot/storage

# Comma-separated list of Telegram user IDs allowed to upload protocols
ADMINS=123456789,987654321
# SQLite database path
DB_PATH=/opt/protocols-bot/storage/protocols.db
